# JWT Settings
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password

# Default User Credentials
DEFAULT_USERNAME=user
DEFAULT_PASSWORD=your_secure_user_password

# Database Connections (used by SQLAlchemy)
AUTH_DATABASE_URL=postgresql+psycopg2://postgres:your_db_password@auth_db:5432/auth_db
ROOM_DATABASE_URL=postgresql+psycopg2://postgres:your_db_password@room_db:5432/room_db
BOOKING_DATABASE_URL=postgresql+psycopg2://postgres:your_db_password@booking_db:5432/booking_db

# PostgreSQL DB Credentials (used by Postgres containers)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password